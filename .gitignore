# ============================================================
# MoltChain — Public Open-Source Repository
# ============================================================
# This .gitignore is tuned for a PUBLIC repo.
# Only core blockchain code is tracked. Everything else
# (frontends, internal docs, infra, fuzz, etc.) stays local.
# ============================================================

# ── Rust build artifacts ────────────────────────────────────
/target/
**/target/
**/*.rs.bk
*.pdb
**/incremental/
**/.fingerprint/
**/deps/

# ── RocksDB / validator state (machine-local) ──────────────
/data/
data/
data-*/
state-*/
/tmp/moltchain-*
/tmp/validator-*
**/*.db
**/*.db-shm
**/*.db-wal

# ── Security-sensitive runtime files ────────────────────────
keypairs/
genesis/
tests/
examples/
genesis.json
genesis-wallet.json
genesis-keys/
validator-*.json
signer-keypair.json
known-peers.json
# NOTE: seeds.json is TRACKED — it contains only public IPs needed for bootstrap
config.toml
airdrops.json
release-signing-keypair.json
faucet-keypair.json

# ── Wallets / artifacts (never commit private keys) ────────
sdk/python/wallets/
sdk/rust/artifacts/

# ── Environment / secrets ──────────────────────────────────
.env
.env.*
*.secret
*.key
*.pem
*.credentials
*.creds

# ── Node / JS ──────────────────────────────────────────────
node_modules/
**/node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test artifacts / output ─────────────────────────────────
tests/artifacts/
tests/__pycache__/
*_test_output.txt

# ── Python ─────────────────────────────────────────────────
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── IDEs and editors ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.iml

# ── Logs & temp ────────────────────────────────────────────
*.log
logs/
*.tmp
.temp/
temp/
tmp/
nohup.out

# ── Backups ────────────────────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.md.backup
*.md.old

# ── Test coverage ──────────────────────────────────────────
coverage/
*.lcov

# ── Contract build artifacts (keep release WASMs) ─────────
contracts/*/target/debug/
contracts/*/target/rls/

# ── Internal-only dev docs ─────────────────────────────────
internal-docs/
FIX_PLAN.md
FIX_PLAN_V2.md
REPOSITORY_STATUS_FEB8.md
PRODUCTION_AUDIT_COMPLETE.md
DEBUGGING_GUIDE.md
validator_genesis_section.txt
Cargo.toml.integration
DEPLOYMENT_STATUS.md
VPS_CREDENTIALS.md

# ── Frontends / proprietary UI (local only) ────────────────
# Note: the open-source faucet backend lives in faucet-service/.
developers/
dex/
faucet/
explorer/
marketplace/
wallet/
website/
shared/
shared-base-styles.css
shared-config.js
shared-theme.css

# ── Internal infrastructure / ops (local only) ─────────────
infra/
deploy/
tools/
monitoring/
docker-compose.yml
Dockerfile
.dockerignore

# ── Internal docs (audits, strategy, deployment, etc.) ─────
docs/

# ── Fuzz testing (internal security tooling) ───────────────
fuzz/

# ── Internal misc (local only) ────────────────────────────
package.json
start-validator.sh
programs/
moltchain/
skills/
typescript
EU/
browser/
archive/

# ── Temp test artefacts ───────────────────────────────────
test1
test2
test3
playground/test-*
deploy-manifest.json
