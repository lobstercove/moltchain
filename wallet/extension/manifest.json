{
  "manifest_version": 3,
  "name": "LichenWallet",
  "description": "Secure, fast, and agent-friendly wallet for Lichen.",
  "version": "0.1.0",
  "icons": {
    "16": "LichenWallet_Logo_256.png",
    "48": "LichenWallet_Logo_256.png",
    "128": "LichenWallet_Logo_256.png"
  },
  "action": {
    "default_title": "LichenWallet",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "LichenWallet_Logo_256.png",
      "24": "LichenWallet_Logo_256.png",
      "32": "LichenWallet_Logo_256.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self' 'unsafe-inline'; connect-src https://rpc.lichen.network https://testnet-rpc.lichen.network http://localhost:8899 https://custody.lichen.network https://testnet-custody.lichen.network http://localhost:9105"
  },
  "options_page": "src/pages/full.html",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://rpc.lichen.network/*",
    "https://testnet-rpc.lichen.network/*",
    "http://localhost:8899/*",
    "https://custody.lichen.network/*",
    "https://testnet-custody.lichen.network/*",
    "http://localhost:9105/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/inpage-provider.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
