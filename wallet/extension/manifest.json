{
  "manifest_version": 3,
  "name": "MoltWallet",
  "description": "Secure, fast, and agent-friendly wallet for MoltChain.",
  "version": "0.1.0",
  "icons": {
    "16": "MoltWallet_Logo_256.png",
    "48": "MoltWallet_Logo_256.png",
    "128": "MoltWallet_Logo_256.png"
  },
  "action": {
    "default_title": "MoltWallet",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "MoltWallet_Logo_256.png",
      "24": "MoltWallet_Logo_256.png",
      "32": "MoltWallet_Logo_256.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_page": "src/pages/full.html",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://rpc.moltchain.network/*",
    "https://testnet-rpc.moltchain.network/*",
    "http://localhost:8899/*",
    "https://custody.moltchain.network/*",
    "https://testnet-custody.moltchain.network/*",
    "http://localhost:9105/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/inpage-provider.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
