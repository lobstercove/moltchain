# ═══════════════════════════════════════════════════════════════════════════════
# Market Maker Bot Dockerfile
# ═══════════════════════════════════════════════════════════════════════════════
FROM node:20-slim

WORKDIR /app

# Copy SDK dependency
COPY dex/sdk /app/dex-sdk
COPY sdk/js /app/lichen-sdk

# Copy market maker
COPY dex/market-maker/package.json dex/market-maker/tsconfig.json ./
RUN npm install

COPY dex/market-maker/src ./src

ENTRYPOINT ["npx", "ts-node", "src/index.ts"]
