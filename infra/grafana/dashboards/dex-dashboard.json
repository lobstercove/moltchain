{
  "annotations": {
    "list": []
  },
  "description": "Lichen DEX Operations Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Chain Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Current Slot",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "chain_slot_height", "legendFormat": "slot" }],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "title": "Pending Transactions",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "pending_transaction_count", "legendFormat": "pending" }],
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] } } }
    },
    {
      "title": "RPC Requests/s",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(rpc_requests_total[1m])", "legendFormat": "{{ method }}" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 }
    },
    {
      "title": "RPC Latency (p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(rpc_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 }
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "ws_active_connections", "legendFormat": "connections" }],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 }
    },
    {
      "title": "DEX Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }
    },
    {
      "title": "Orders/s",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(dex_orders_total[1m])", "legendFormat": "placed" },
        { "expr": "rate(dex_cancels_total[1m])", "legendFormat": "cancelled" },
        { "expr": "rate(dex_fills_total[1m])", "legendFormat": "filled" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 11 }
    },
    {
      "title": "Swap Volume",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(dex_swap_volume_total[5m])", "legendFormat": "{{ pair }}" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 11 }
    },
    {
      "title": "Insurance Fund Balance",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "dex_insurance_fund_balance", "legendFormat": "LICN" }],
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 11 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "green", "value": 50000 }] }, "unit": "short" } }
    },
    {
      "title": "Active Margin Positions",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "dex_margin_positions_active", "legendFormat": "positions" }],
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 11 }
    },
    {
      "title": "Liquidations (24h)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "increase(dex_liquidations_total[24h])", "legendFormat": "liquidations" }],
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 15 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "title": "AMM Pool TVL",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "dex_pool_tvl", "legendFormat": "{{ pool }}" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 }
    }
  ],
  "schemaVersion": 38,
  "tags": ["lichen", "dex"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Lichen DEX Operations",
  "uid": "lichendex-ops",
  "version": 1
}
